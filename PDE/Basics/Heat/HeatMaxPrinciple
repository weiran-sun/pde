lemma deriv_nonneg_of_isLocalMaxOn_Icc_right_S
    {f : ℝ → ℝ} {T : ℝ} (hT : 0 < T)
    (hC1 : ContDiffOn ℝ 1 f (Icc 0 T))
    (hmax : IsLocalMaxOn f (Icc 0 T) T) :
    0 ≤ derivWithin f (Icc 0 T) T := by

    have hdiff := (hC1 T ⟨hT.le, le_rfl⟩).differentiableWithinAt le_rfl

    have hy : (-T : ℝ) ∈ posTangentConeAt (Icc 0 T) T := by
      apply mem_posTangentConeAt_of_segment_subset
      rintro _ ⟨c, d, hc, hd, hsum, rfl⟩
      simp only [smul_eq_mul]
      exact ⟨by nlinarith, by nlinarith⟩

    have hnonpos := hmax.hasFDerivWithinAt_nonpos hdiff.hasFDerivWithinAt hy

    have hEq : fderivWithin ℝ f (Icc 0 T) T (-T) = derivWithin f (Icc 0 T) T * -T := by
      rw [show (-T : ℝ) = -T • 1 by simp, map_smul]
      simp [fderivWithin_derivWithin, mul_comm]

    rw [hEq] at hnonpos
    nlinarith

lemma heat_equation_no_top_edge_max
  {l T α ε : ℝ} {u v : ℝ → ℝ → ℝ}
  (hT : 0 < T) (hl : 0 < l) (hα : 0 < α) (hε : 0 < ε)
  (hv_def : v = fun x t ↦ u x t + ε * x ^ 2)
  (h_smooth : ContDiffOn ℝ 2 (fun p : ℝ × ℝ ↦ u p.1 p.2) (Ω_T l T))
  (h_pde : ∀ x t, (x, t) ∈ Interior l T →
    deriv (fun t' ↦ u x t') t = α * deriv (fun x' ↦ deriv (fun x'' ↦ u x'' t) x') x) :
  ∀ x₀, 0 < x₀ → x₀ < l → ¬ IsMaxOn (fun p ↦ v p.1 p.2) (Ω_T l T) (x₀, T) := by
  intro x₀ hx0_pos hx0_lt hmax

  let v_space : ℝ → ℝ := fun x ↦ v x T
  let v_time : ℝ → ℝ := fun t ↦ v x₀ t

  have h_vxx_le : deriv (deriv v_space) x₀ ≤ 0 :=
    (local_max_implies_second_deriv_nonpos (by
      subst hv_def
      exact ((h_smooth.comp (contDiff_id.prodMk contDiff_const).contDiffOn fun x hx ↦ ⟨⟨hx.1.le, hx.2.le⟩, ⟨hT.le, le_rfl⟩⟩).contDiffAt
             (Ioo_mem_nhds hx0_pos hx0_lt)).add (contDiff_const.mul (contDiff_id.pow 2)).contDiffAt)
      ((show IsMaxOn v_space (Ioo 0 l) x₀ from fun x hx ↦ hmax (⟨⟨hx.1.le, hx.2.le⟩, ⟨hT.le, le_rfl⟩⟩ :
      (x, T) ∈ Ω_T l T)).isLocalMax (Ioo_mem_nhds hx0_pos hx0_lt))).2
  have h_vt_ge : 0 ≤ derivWithin v_time (Iic T) T := by
    have h_vt_eq : derivWithin v_time (Iic T) T = derivWithin v_time (Icc 0 T) T := by
      apply derivWithin_congr_set'
      refine eventually_of_mem (mem_nhdsWithin_of_mem_nhds (Ioo_mem_nhds hT (lt_add_one T)))
             fun y hy ↦ propext ⟨fun h ↦ ⟨hy.1.le, h⟩, fun h ↦ h.2⟩
      subst hv_def
      simp_all only [v_space]
      exact l
    rw [h_vt_eq]
    exact deriv_nonneg_of_isLocalMaxOn_Icc_right_S hT (by
      subst hv_def
      exact ((h_smooth.of_le (by norm_num)).comp (ContDiff.prodMk (contDiff_const : ContDiff ℝ 1 fun _ ↦ x₀)
            (contDiff_id : ContDiff ℝ 1 id)).contDiffOn fun t ht ↦ ⟨⟨hx0_pos.le, hx0_lt.le⟩, ht⟩).add
            (contDiff_const : ContDiff ℝ 1 fun _ ↦ ε * x₀ ^ 2).contDiffOn)
            (Filter.eventually_of_mem self_mem_nhdsWithin fun t ht ↦ show v_time t ≤ v_time T from hmax
            (⟨⟨hx0_pos.le, hx0_lt.le⟩, ht⟩ : (x₀, t) ∈ Ω_T l T))

  have hpde_eq : derivWithin v_time (Iic T) T - α * deriv (deriv v_space) x₀ = -2 * α * ε := by
    subst hv_def
    exact pde_boundary_val hT hl hx0_pos hx0_lt h_smooth h_pde

  nlinarith

lemma max_v_on_S_boundary
  {l T : ℝ} {v : ℝ → ℝ → ℝ}
  (hT : 0 < T)
  (h_compact : IsCompact (Ω_T l T))
  (h_nonempty : (Ω_T l T).Nonempty)
  (h_v_cont : ContinuousOn (fun p : ℝ × ℝ ↦ v p.1 p.2) (Ω_T l T))
  (h_no_int : ∀ x₀ t₀, (x₀, t₀) ∈ Interior l T → ¬ IsMaxOn (fun p ↦ v p.1 p.2) (Ω_T l T) (x₀, t₀))
  (h_no_top : ∀ x₀, 0 < x₀ → x₀ < l → ¬ IsMaxOn (fun p ↦ v p.1 p.2) (Ω_T l T) (x₀, T)) :
  ∃ s_max ∈ S_boundary l T, ∀ p ∈ Ω_T l T, v p.1 p.2 ≤ v s_max.1 s_max.2 := by
  obtain ⟨⟨x₀, t₀⟩, hp_max_in, hp_max_val⟩ := h_compact.exists_isMaxOn h_nonempty h_v_cont
  rcases Omega_T_decompose hp_max_in with h_S | h_Int | h_Top
  · exact ⟨(x₀, t₀), h_S, hp_max_val⟩
  · exact False.elim (h_no_int x₀ t₀ h_Int hp_max_val)
  · simp only [Top_Edge, Set.mem_prod, Set.mem_Ioo, Set.mem_singleton_iff] at h_Top
    rcases h_Top with ⟨⟨hx_pos, hx_lt⟩, rfl⟩
    exact False.elim (h_no_top x₀ hx_pos hx_lt hp_max_val)

------------------------------------------------------------------
  -- Theorem:
  --
  --Suppose u ∈ C²(Ω_T) and u satisfies the heat equation in the interior
  --of Ω_T. Then max_{S_boundary} u = max_{Ω_T} u.
  --
------------------------------------------------------------------

theorem heat_equation_max_principle
  (u : ℝ → ℝ → ℝ) (hl : 0 < l) (hT : 0 < T) (hα : 0 < α)
  (h_smooth : ContDiffOn ℝ 2 (fun p : ℝ × ℝ => u p.1 p.2) (Ω_T l T))
  (h_pde : ∀ x t, (x, t) ∈ Interior l T →
    deriv (fun t' => u x t') t = α * deriv (fun x' => deriv (fun x'' => u x'' t) x') x) :
  sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) =
        sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) := by

  have h_compact : IsCompact (Ω_T l T) := isCompact_Icc.prod isCompact_Icc
  have h_nonempty : (Ω_T l T).Nonempty := ⟨(0, 0), by simp [Ω_T, hl.le, hT.le]⟩
  have h_Snonempty : (S_boundary l T).Nonempty := ⟨(0, 0), by simp [S_boundary, hl.le, hT.le]⟩
  have h_Scompact : IsCompact (S_boundary l T) := by
      unfold S_boundary
      exact (isCompact_Icc.prod isCompact_singleton).union
        (isCompact_singleton.prod isCompact_Icc) |>.union
        (isCompact_singleton.prod isCompact_Icc)

  have h_sub : S_boundary l T ⊆ Ω_T l T := by
    intro ⟨x, t⟩ h
    simp only [S_boundary, Ω_T, Set.mem_union, Set.mem_prod,
              Set.mem_Icc, Set.mem_singleton_iff] at h ⊢
    rcases h with ⟨hx, rfl⟩ | ⟨rfl, ht⟩ | ⟨rfl, ht⟩ <;>
    refine ⟨⟨?_, ?_⟩, ?_, ?_⟩ <;> linarith [hl.le, hT.le]

  have h_cont : ContinuousOn (fun p : ℝ × ℝ => u p.1 p.2) (Ω_T l T) := by
    exact h_smooth.continuousOn

  have h_Scont : ContinuousOn (fun p : ℝ × ℝ => u p.1 p.2) (S_boundary l T) :=
      h_cont.mono h_sub

  have hΩu_ne : (((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) : Set ℝ).Nonempty := by
    rcases h_nonempty with ⟨p, hp⟩
    exact ⟨u p.1 p.2, ⟨p, hp, rfl⟩⟩

  have hΩu_bdd : BddAbove (((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) : Set ℝ) := by
    simpa using (h_compact.image_of_continuousOn h_cont).bddAbove

  have hSbdy_u_bdd : BddAbove ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) := by
    simpa using (h_Scompact.image_of_continuousOn h_Scont).bddAbove

  have hSbdy_u_ne :
      (((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) : Set ℝ).Nonempty := by
    rcases h_Snonempty with ⟨p, hp⟩
    exact ⟨u p.1 p.2, ⟨p, hp, rfl⟩⟩

  have main_step: ∀ ε > 0,
    sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T))
      ≤ sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) + ε * l^2 := by

    intro ε hε
    set v := fun x t ↦ u x t + ε * x ^ 2 with hv_def

    have hΩv_bdd : BddAbove (((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T)) : Set ℝ) := by
      simpa using (h_compact.image_of_continuousOn (by fun_prop)).bddAbove

    have hΩv_ne : (((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T)) : Set ℝ).Nonempty := by
      rcases h_nonempty with ⟨p, hp⟩
      exact ⟨v p.1 p.2, ⟨p, hp, rfl⟩⟩

    have hSbdy_v_bdd : BddAbove ((fun p : ℝ × ℝ => v p.1 p.2) '' (S_boundary l T)) := by
      simpa using (h_Scompact.image_of_continuousOn (by fun_prop)).bddAbove

    have hSbdy_v_ne : (((fun p : ℝ × ℝ => v p.1 p.2) '' (S_boundary l T)) : Set ℝ).Nonempty := by
      rcases h_Snonempty with ⟨p, hp⟩
      exact ⟨v p.1 p.2, ⟨p, hp, rfl⟩⟩

    have Step1 : sSup ((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T)) = sSup ((fun p : ℝ × ℝ => v p.1 p.2) '' (S_boundary l T)) := by
      refine le_antisymm (csSup_le hΩv_ne ?_) (csSup_le hSbdy_v_ne ?_)
      · have hv_cont : ContinuousOn (fun p ↦ v p.1 p.2) (Ω_T l T) := by
          dsimp [v]; exact h_cont.add (continuousOn_const.mul (continuousOn_fst.pow 2))
        obtain ⟨s, hs_in, hs_val⟩ := max_v_on_S_boundary (v := v) hT h_compact h_nonempty hv_cont
          (heat_equation_no_interior_max (ε:=ε) (u:=u) (v:=v) hα hv_def h_smooth h_int_nhds <| heat_equation_perturbation_ineq hα hε hv_def h_smooth h_pde)
          (heat_equation_no_top_edge_max (ε:=ε) (u:=u) (v:=v) hT hl hα hε hv_def h_smooth h_pde)
        rintro _ ⟨p, hp, rfl⟩
        exact (hs_val p hp).trans (le_csSup hSbdy_v_bdd ⟨s, hs_in, rfl⟩)
      · rintro _ ⟨p, hp, rfl⟩
        exact le_csSup hΩv_bdd ⟨p, h_sub hp, rfl⟩

    have Step2 :
        sSup ((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T)) ≥
          sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) := by
        show sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) ≤
            sSup ((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T))
        refine csSup_le hΩu_ne ?_
        rintro y ⟨p, hp, rfl⟩
        refine le_trans ?_ (le_csSup hΩv_bdd ⟨p, hp, rfl⟩)
        dsimp [v]
        have : 0 ≤ ε * p.1 ^ 2 := by positivity
        linarith

    have Step3 :
        sSup ((fun p : ℝ × ℝ => v p.1 p.2) '' (Ω_T l T)) ≤
          sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) + ε * l^2 := by
      rw [Step1]
      refine csSup_le ?_ ?_
      · exact ⟨v 0 0, ⟨(0, 0), by simp [S_boundary, hl.le, hT.le], rfl⟩⟩
      · rintro y ⟨⟨x, t⟩, hp, rfl⟩
        have hx2 : x ^ 2 ≤ l ^ 2 := by
          rcases hp with (⟨⟨h0, hl'⟩, _⟩ | ⟨rfl, _⟩ | ⟨rfl, _⟩)
          · nlinarith
          · rename_i h_mem;
            simp [Set.mem_prod, Set.mem_singleton_iff] at h_mem; nlinarith
          · rfl
        refine le_trans ?_ (add_le_add_right (le_csSup hSbdy_u_bdd ⟨(x, t), hp, rfl⟩) _)
        simp only [v]
        nlinarith [mul_le_mul_of_nonneg_left hx2 hε.le]
    exact le_trans Step2 Step3

  have Step4 :
    sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) ≤
      sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) := by
      apply le_of_forall_pos_le_add
      intro δ hδ
      linarith [main_step (δ / l ^ 2) (by positivity),
                div_mul_cancel₀ δ (pow_ne_zero 2 hl.ne')]

  have Step5 :
      sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) ≥
        sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)) := by
    have h_le :
        ∀ y ∈ ((fun p : ℝ × ℝ => u p.1 p.2) '' (S_boundary l T)),
          y ≤ sSup ((fun p : ℝ × ℝ => u p.1 p.2) '' (Ω_T l T)) := by
      intro y hy
      rcases hy with ⟨p, hp, rfl⟩
      exact le_csSup hΩu_bdd ⟨p, h_sub hp, rfl⟩
    exact csSup_le hSbdy_u_ne h_le

  exact le_antisymm Step4 Step5


end HeatEquation
