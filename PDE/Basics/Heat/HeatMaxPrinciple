lemma Omega_T_decompose {l T : ℝ} {p : ℝ × ℝ} (hp : p ∈ Ω_T l T) :
  p ∈ S_boundary l T ∨ p ∈ Interior l T ∨ p ∈ Top_Edge l T := by
  obtain ⟨x, t⟩ := p
  simp only [Ω_T, S_boundary, Interior, Top_Edge, Set.mem_prod, Set.mem_Icc,
    Set.mem_union, Set.mem_singleton_iff, Set.mem_Ioo] at hp ⊢
  obtain ⟨⟨hx0, hxl⟩, ⟨ht0, htT⟩⟩ := hp
  rcases lt_or_eq_of_le hx0 with hx0_lt | rfl
  · rcases lt_or_eq_of_le hxl with hxl_lt | rfl
    · rcases lt_or_eq_of_le ht0 with ht0_lt | rfl
      · rcases lt_or_eq_of_le htT with htT_lt | rfl
        · right; left; exact ⟨⟨hx0_lt, hxl_lt⟩, ⟨ht0_lt, htT_lt⟩⟩
        · right; right; exact ⟨⟨hx0_lt, hxl_lt⟩, rfl⟩
      · left; left; left; exact ⟨⟨hx0, hxl⟩, rfl⟩
    · left; right; exact ⟨rfl, ht0, htT⟩
  · left; left; right; exact ⟨rfl, ht0, htT⟩

